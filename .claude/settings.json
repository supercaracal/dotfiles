{
  "model": "sonnet",
  "effortLevel": "high",
  "disableBypassPermissionsMode": "disable",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "WebFetch",
      "Agent",
      "mcp__claude_ai"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.aws)",
      "Bash(sudo *)",
      "Bash(su *)"
    ],
    "defaultMode": "dontAsk"
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "crates.io",
        "*.crates.io",
        "registry.npmjs.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.cargo",
        "~/.npm"
      ],
      "allowRead": [
        "~/.cargo",
        "~/.npm",
        "~/.ssh/known_hosts"
      ]
    }
  }
}
