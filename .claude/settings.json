{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash",
      "WebFetch",
      "Agent",
      "mcp__claude_ai"
    ],
    "deny": [
      "Read(~/.ssh)",
      "Read(~/.aws)",
      "Bash(sudo *)",
      "Bash(su *)"
    ],
    "defaultMode": "dontAsk"
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "sandbox": {
    "enabled": true
  },
  "effortLevel": "high",
  "disableBypassPermissionsMode": "disable"
}
